{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"outDir": "dist/server",
		"rootDir": "src",
		"declaration": false
	},
	"include": ["src/server/**/*", "src/shared/**/*"],
	"exclude": ["src/server/**/*.test.ts", "src/shared/**/*.test.ts"]
}
