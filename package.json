{
	"name": "pi-web",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"postinstall": "npx patch-package",
		"dev": "./dev.sh",
		"dev:server": "tsx watch src/server/server.ts",
		"dev:client": "vite",
		"build": "vite build && bun build src/server/server.ts --target=bun --outdir=dist/server --entry-naming=server.js",
		"start": "NODE_ENV=production bun run dist/server/server.js",
		"prod": "./prod.sh",
		"check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:screenshots": "node node_modules/@playwright/test/cli.js test -c playwright.config.ts e2e/ui-screenshots.e2e.ts"
	},
	"dependencies": {
		"@mariozechner/mini-lit": "^0.2.0",
		"@mariozechner/pi-agent-core": "0.55.3",
		"@mariozechner/pi-ai": "0.55.3",
		"@mariozechner/pi-coding-agent": "0.55.3",
		"@mariozechner/pi-web-ui": "0.55.3",
		"patch-package": "^8.0.1",
		"@tailwindcss/vite": "^4.1.17",
		"express": "^5.1.0",
		"lit": "^3.3.1",
		"lucide": "^0.544.0",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@types/express": "^5.0.0",
		"@types/ws": "^8.5.10",
		"concurrently": "^9.0.0",
		"happy-dom": "^20.7.0",

		"tsx": "^4.19.0",
		"typescript": "^5.7.3",
		"vite": "^7.1.6",
		"vitest": "^3.2.4"
	}
}
